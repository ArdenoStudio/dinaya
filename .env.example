# Neon Postgres (https://neon.tech)
DATABASE_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
SECRET_ENCRYPTION_KEY=
AUTH_URL=https://dinaya.lk

# PayHere (https://payhere.lk/developers)
PAYHERE_SANDBOX=true   # set to false in production

# Dinaya's own PayHere merchant account (for billing the Pro plan).
# Separate from per-business PayHere creds, which are stored in the DB per business.
DINAYA_PAYHERE_MERCHANT_ID=
DINAYA_PAYHERE_MERCHANT_SECRET=
# Business App credentials from the PayHere dashboard — used for the
# Subscription Manager API (cancel/retry from server).
DINAYA_PAYHERE_APP_ID=
DINAYA_PAYHERE_APP_SECRET=
# Plan prices are managed through src/lib/plan.ts defaults and /admin/plans.
# Current defaults: Starter 1,990/mo, Pro 3,990/mo, Growth 6,900/mo.

# Scheduled cron auth — set the same value in the app env and GitHub Actions secret.
CRON_SECRET=

# GitHub Actions: set repository variable or secret DINAYA_APP_URL (e.g. https://dinaya.lk)
# alongside CRON_SECRET for all cron workflows.

# Google Calendar OAuth (dashboard integration + public booking calendar overlay)
# For the booking overlay, enable the Calendar API and add NEXT_PUBLIC_APP_URL's
# origin (for example https://dinaya.lk) as an Authorized JavaScript origin.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional dedicated secret for /api/health/* (falls back to CRON_SECRET)
HEALTH_CHECK_SECRET=

# Admin /admin/health — optional Upptime summary.json (30d history + incidents).
# Without these, /admin/health still shows live DB / email / PayHere probes.
# UPTIME_MONITOR_SUMMARY_URL=https://raw.githubusercontent.com/ArdenoStudio/dinaya-uptime-monitor/master/history/summary.json
# UPTIME_MONITOR_GITHUB_REPO=ArdenoStudio/dinaya-uptime-monitor
# UPTIME_MONITOR_GITHUB_BRANCH=master   # omit to try master then main
# UPTIME_MONITOR_GITHUB_TOKEN=   # required for private repos (uses GitHub Contents API)

# Optional Upstash Redis for distributed rate limiting (falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Contact form inbox (defaults to hello@dinaya.lk)
CONTACT_INBOX_EMAIL=
# Optional public support WhatsApp number. If unset, public WhatsApp support links are hidden.
NEXT_PUBLIC_SUPPORT_WHATSAPP_NUMBER=

# Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=noreply@dinaya.lk

# Optional AI copy provider. If unset, Dinaya uses deterministic Sri Lanka-local fallback copy.
# Groq (recommended): AI_PROVIDER=groq, GROQ_API_KEY=gsk_...
AI_PROVIDER=groq
GROQ_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_REACTIVATION_DAYS=30

# Meta Cloud API for WhatsApp reminders and approved social publishing.
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
# Inbound WhatsApp webhook (two-way bot): a verify token you choose + the Meta app secret (for X-Hub signature checks).
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=
# Soft-cap WhatsApp at each plan's monthly allowance, falling back to email. Unset/false = observe usage only (recommended at launch).
MESSAGING_ENFORCE_ALLOWANCE=false
META_SOCIAL_ACCESS_TOKEN=
META_SOCIAL_PAGE_ID=

# Twilio WhatsApp sandbox fallback (trial: whatsapp:+14155238886)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Voice Phase 2 — Twilio ConversationRelay WebSocket URL (optional)
TWILIO_CONVERSATION_RELAY_WS_URL=

# Generic SMS HTTP gateway. If unset, SMS sends are logged as skipped.
SMS_HTTP_ENDPOINT=
SMS_HTTP_API_KEY=
SMS_HTTP_METHOD=POST
SMS_HTTP_SENDER=Dinaya

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Microsoft Clarity — free session replay + heatmaps. Create a project at clarity.microsoft.com, then paste its project ID.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Set to "true" to log every analytics event to the browser console (verify wiring without GA). Auto-on under `next dev`.
NEXT_PUBLIC_ANALYTICS_DEBUG=

# Vercel custom-domain automation (required for tenant-owned domains)
VERCEL_TOKEN=
VERCEL_PROJECT_ID_OR_NAME=
# Optional for team projects
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=

# Platform admin (internal Dinaya/Ardeno staff)
# Comma-separated list of emails allowed to access /admin
PLATFORM_ADMIN_EMAILS=
