# Neon Postgres (https://neon.tech)
DATABASE_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
SECRET_ENCRYPTION_KEY=
AUTH_URL=https://dinaya.lk

# PayHere (https://payhere.lk/developers)
PAYHERE_SANDBOX=true   # set to false in production

# Dinaya's own PayHere merchant account (for billing the Pro plan).
# Separate from per-business PayHere creds, which are stored in the DB per business.
DINAYA_PAYHERE_MERCHANT_ID=
DINAYA_PAYHERE_MERCHANT_SECRET=
# Business App credentials from the PayHere dashboard — used for the
# Subscription Manager API (cancel/retry from server).
DINAYA_PAYHERE_APP_ID=
DINAYA_PAYHERE_APP_SECRET=
# Subscription prices in LKR (integer rupees).
DINAYA_PRO_MONTHLY_PRICE_LKR=1490
DINAYA_PRO_ANNUAL_PRICE_LKR=14300
DINAYA_MAX_MONTHLY_PRICE_LKR=2490
DINAYA_MAX_ANNUAL_PRICE_LKR=23900

# Scheduled cron auth — set the same value in the app env and GitHub Actions secret.
CRON_SECRET=

# Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=noreply@dinaya.lk

# Optional AI copy provider. If unset, Dinaya uses deterministic Sri Lanka-local fallback copy.
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Meta Cloud API for WhatsApp reminders and approved social publishing.
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_SOCIAL_ACCESS_TOKEN=
META_SOCIAL_PAGE_ID=

# Generic SMS HTTP gateway. If unset, SMS sends are logged as skipped.
SMS_HTTP_ENDPOINT=
SMS_HTTP_API_KEY=
SMS_HTTP_METHOD=POST
SMS_HTTP_SENDER=Dinaya

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Platform admin (internal Dinaya/Ardeno staff)
# Comma-separated list of emails allowed to access /admin
PLATFORM_ADMIN_EMAILS=
