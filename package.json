{
  "name": "dinaya",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "node scripts/next-build.mjs",
    "start": "next start",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:dev:local-api": "npm --prefix apps/desktop run dev:local-api",
    "desktop:audit": "node scripts/desktop-production-readiness.mjs",
    "desktop:build": "npm --prefix apps/desktop run build",
    "desktop:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-smoke.ps1",
    "mcp:dinaya": "npm --prefix apps/mcp-dinaya run start",
    "mcp:dinaya:audit": "npm --prefix apps/mcp-dinaya audit --audit-level=high",
    "mcp:dinaya:self-test": "npm --prefix apps/mcp-dinaya run self-test",
    "video:lint": "npm --prefix apps/video run lint",
    "subapps:verify": "npm run mcp:dinaya:self-test && npm run mcp:dinaya:audit && npm run video:lint",
    "test": "vitest run",
    "test:routes:generate": "node scripts/generate-route-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:live": "PLAYWRIGHT_BASE_URL=https://dinaya-lk.vercel.app playwright test e2e/live-vercel.spec.ts",
    "test:e2e:full": "E2E_DISABLE_RATE_LIMIT=true playwright test",
    "seed:test-services": "tsx scripts/seed-test-services.ts",
    "seed:test-branding": "tsx scripts/seed-test-branding.ts",
    "seed:test-reviews": "tsx scripts/seed-test-reviews.ts --avg 4.7 --count 1500",
    "seed:test-booking": "tsx scripts/seed-test-booking.ts",
    "seed:pilot-wax": "tsx scripts/seed-pilot-wax.ts",
    "setup:wax": "node scripts/setup-wax.mjs",
    "seed:personas": "tsx scripts/seed-e2e-personas.ts",
    "seed:personas:clean": "tsx scripts/seed-e2e-personas.ts --clean",
    "seed:personas:enrich": "tsx scripts/seed-e2e-personas.ts --enrich-rich",
    "seed:personas:manifest": "tsx scripts/rebuild-persona-manifest.ts",
    "test:personas": "E2E_DISABLE_RATE_LIMIT=true tsx scripts/run-persona-journeys.ts",
    "test:e2e:personas": "E2E_DISABLE_RATE_LIMIT=true playwright test e2e/personas.spec.ts",
    "lint": "eslint . --max-warnings=0",
    "verify": "npm run lint && npm run desktop:audit && npm test && npm run build",
    "audit:high": "npm audit --audit-level=high",
    "payhere:check": "node scripts/payhere-readiness.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "docs:screenshots": "npx tsx scripts/capture-docs-screenshots.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@neondatabase/serverless": "^0.10.4",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.14",
    "@supabase/supabase-js": "^2.108.2",
    "@tsparticles/react": "^4.1.3",
    "@tsparticles/slim": "^4.1.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.513.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.29",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "resend": "^4.5.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.3",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.27.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.10",
    "shadcn": "^4.8.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": ">=0.28.1"
  }
}
