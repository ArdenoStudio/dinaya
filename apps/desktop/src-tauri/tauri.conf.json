{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dinaya Desktop",
  "version": "0.1.1",
  "identifier": "lk.dinaya.desktop",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://dinaya.lk https://*.dinaya.lk; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Dinaya",
        "minWidth": 1024,
        "minHeight": 700,
        "width": 1280,
        "height": 860
      }
    ]
  },
  "bundle": {
    "active": true,
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "nsis",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
