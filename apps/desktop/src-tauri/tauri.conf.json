{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dinaya Desktop",
  "version": "0.1.0",
  "identifier": "lk.dinaya.desktop",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Dinaya",
        "url": "index.html",
        "minWidth": 1024,
        "minHeight": 700,
        "width": 1280,
        "height": 860
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
