{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["../../src/*"]
    }
  },
  "include": ["src", "../../src/components", "../../src/lib"]
}
